# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.astro/
.turbo/
coverage/

# Local Claude config (machine-specific, never shared)
.claude/settings.local.json
.claude/.env

# Secrets: never commit credentials, Application Passwords, or licence keys
.env
.env.*
!.env.example
*.pem
*.key

# OS and editor
.DS_Store
Thumbs.db
nul
*.swp
.vscode/
.idea/

# Client working material (client sites live in their own repos, not here)
clients/
sites/

# Designer pack output: generated by designer-pack/assemble.sh from docs/.
# Not committed, so there is never a stale second copy of a document in Git.
designer-pack/documents/
